# 下载字体到临时目录，比如Downloads
cd ~/Downloads
wget -O JetBrainsMono.zip https://github.com/ryanoasis/nerd-fonts/releases/download/v3.0.2/JetBrainsMono.zip
# 创建系统字体子目录
sudo mkdir -p /usr/share/fonts/truetype/jetbrains-nerd
# 解压到该目录
sudo unzip JetBrainsMono.zip -d /usr/share/fonts/truetype/jetbrains-nerd/
# 刷新系统字体缓存
sudo fc-cache -f -v
#终端选择新字体
