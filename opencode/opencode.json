{
	"$schema": "https://opencode.ai/config.json",
	"provider": {
		"openai": {
			"options": {
				"baseURL": "https://api.moonshot.cn/v1",
				"timeout": 600000
			}
		}
	},
	"model": "kimi-for-coding/k2p5",
	"plugin": [
		"opencode-enhancer-plugin@latest"
	],
	"agent": {
		"enhancer": {
			"model": "kimi-for-coding/k2p5"
		},
		"ultraplan": {
			"model": "kimi-for-coding/k2p5"
		},
		"ask": {
			"model": "kimi-for-coding/k2p5"
		},
		"strategos": {
			"model": "kimi-for-coding/k2p5"
		},
		"explore-context": {
			"model": "kimi-for-coding/k2p5"
		},
		"explore-code": {
			"model": "kimi-for-coding/k2p5"
		},
		"explore-deps": {
			"model": "kimi-for-coding/k2p5"
		},
		"explore-tests": {
			"model": "kimi-for-coding/k2p5"
		},
		"review-plan": {
			"model": "kimi-for-coding/k2p5"
		},
		"strategos-interviewer": {
			"model": "kimi-for-coding/k2p5"
		}
  }
}
